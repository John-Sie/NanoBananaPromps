        {
          "id": "std-75",
          "name_zh": "图片生成微缩场景",
          "name_en": "Generate Miniature Scene from Image",
          "author": "@techhalla",
          "source_url": "https://x.com/techhalla/status/1962088250199163285",
          "requires_input": true,
          "input_description": "需上传一张参考图像",
