          "requires_input": true,
          "input_description": "需上传一张参考图片",
          "prompt_zh": "您能否帮我使用这座建筑的纹理生成一个装饰图集？",
          "prompt_en": "Can you help me generate a decorative atlas using the texture of this building?",
          "variables": [],
