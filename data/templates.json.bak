        {
          "id": "pro-16",
          "name_zh": "揭秘照片的幕后制作过程",
          "name_en": "Reveal Behind-the-Scenes of Photo Creation",
          "author": "@icreatelife",
          "source_url": "https://x.com/icreatelife/status/1991945836914147524?s=20",
          "requires_input": true,
          "input_description": "需上传一张参考图片",
          "prompt_zh": "我想看看这张照片拍摄的幕后花絮，了解它是如何诞生的。",
          "prompt_en": "I want to see the behind-the-scenes of this photo shoot and understand how it was born.",
          "variables": [],
