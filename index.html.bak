<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO Meta Tags -->
  <title>Nano Banana 提示詞大師</title>
  <meta name="description" content="Nano Banana 提示詞模板管理工具，162 個精選提示詞模板，場景引導式生圖">
  <meta name="keywords" content="Nano Banana, 提示詞, prompt, AI 生圖, 模板, 場景引導">
  <meta name="author" content="Nano Banana">
  <meta name="robots" content="index, follow">

  <!-- Open Graph Tags -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Nano Banana 提示詞大師">
  <meta property="og:description" content="Nano Banana 提示詞模板管理工具，162 個精選提示詞模板，場景引導式生圖">
  <meta property="og:site_name" content="Nano Banana 提示詞大師">
  <meta property="og:locale" content="zh_TW">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Nano Banana 提示詞大師">
  <meta name="twitter:description" content="Nano Banana 提示詞模板管理工具，162 個精選提示詞模板，場景引導式生圖">

  <!-- Favicon: 🍌 emoji as SVG data URI -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🍌</text></svg>" type="image/svg+xml">

  <!-- Stylesheet -->
  <link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- ============================
     App Container
     ============================ -->
<div id="app" class="app-container">

  <!-- ============================
       側邊欄 Sidebar
       ============================ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="logo" data-i18n="sidebar.logo">🍌 提示詞大師</div>
      <button class="btn-icon sidebar-toggle" id="sidebarToggle" data-i18n-title="modal.close" aria-label="切換側邊欄">☰</button>
    </div>

    <!-- 分類導航 -->
    <div class="sidebar-section">
      <h3 class="sidebar-title" data-i18n="sidebar.title">分類</h3>
      <ul class="category-list" id="categoryList">
        <li class="category-item active" data-category="all">
          <span class="category-icon" aria-hidden="true">📋</span>
          <span class="category-name" data-i18n="sidebar.all">全部模板</span>
          <span class="category-count" id="countAll">0</span>
        </li>
        <li class="category-item" data-category="nano-banana-pro">
          <span class="category-icon" aria-hidden="true">🍌</span>
          <span class="category-name" data-i18n="sidebar.pro">Nano Banana Pro</span>
          <span class="category-count" id="countPro">0</span>
        </li>
        <li class="category-item" data-category="nano-banana">
          <span class="category-icon" aria-hidden="true">🖼️</span>
          <span class="category-name" data-i18n="sidebar.standard">Nano Banana</span>
          <span class="category-count" id="countStandard">0</span>
        </li>
        <li class="category-item" data-category="favorites">
          <span class="category-icon" aria-hidden="true">⭐</span>
          <span class="category-name" data-i18n="sidebar.favorites">我的收藏</span>
          <span class="category-count" id="countFavorites">0</span>
        </li>
        <li class="category-item" data-category="custom">
          <span class="category-icon" aria-hidden="true">✏️</span>
          <span class="category-name" data-i18n="sidebar.custom">自訂模板</span>
          <span class="category-count" id="countCustom">0</span>
        </li>
      </ul>
    </div>
  </aside>

  <!-- ============================
       主內容區 Main Content
       ============================ -->
  <main class="main-content">

    <!-- 頂部導航 Header -->
    <header class="header" id="header">
      <div class="header-left">
        <button class="btn-icon mobile-menu" id="mobileMenu" aria-label="開啟選單">☰</button>
        <h1 class="header-title">🍌 Nano Banana</h1>
      </div>
      
      <!-- 居中搜尋框 -->
      <div class="header-center">
        <div class="search-box header-search">
          <span class="search-icon" aria-hidden="true">🔍</span>
          <input type="text" id="searchInput" data-i18n-placeholder="header.search_placeholder" placeholder="搜尋 162 個精選模板... (按 / 聚焦)" aria-label="搜尋模板">
          <button class="search-clear" id="searchClear" aria-label="清除搜尋">✕</button>
          <span class="search-shortcut" aria-hidden="true">/</span>
        </div>
      </div>

      <!-- 右側高質感工具組 -->
      <div class="header-right">
        <!-- 全域語言切換選單 Dropdown -->
        <div class="lang-dropdown-container">
          <button class="btn-icon header-tool-btn lang-dropdown-trigger" id="langDropdownTrigger" data-i18n-title="header.lang_tooltip" title="選擇語言 / Language" aria-label="選擇語言" aria-haspopup="true" aria-expanded="false">🌐</button>
          <div class="lang-dropdown-menu" id="langDropdownMenu" role="menu" aria-hidden="true">
            <button class="lang-dropdown-item active" data-lang="zh" role="menuitem">繁體中文</button>
            <button class="lang-dropdown-item" data-lang="en" role="menuitem">English</button>
            <button class="lang-dropdown-item" data-lang="ja" role="menuitem">日本語</button>
            <button class="lang-dropdown-item" data-lang="ko" role="menuitem">한국어</button>
          </div>
        </div>
        <!-- 圖片風格分析 -->
        <button class="btn-icon header-tool-btn" id="imageAnalysisBtn" data-i18n-title="header.analysis_tooltip" title="圖片風格分析" aria-label="圖片風格分析">🔬</button>
        <!-- 新增自訂模板 -->
        <button class="btn-icon header-tool-btn" id="addCustomBtn" data-i18n-title="header.add_custom_tooltip" title="新增自訂模板" aria-label="新增自訂模板">✏️</button>
        <!-- 主題切換 -->
        <button class="btn-icon theme-toggle header-tool-btn" id="themeToggle" data-i18n-title="header.theme_tooltip" title="切換主題" aria-label="切換主題">
          <span class="theme-icon-light" aria-hidden="true">☀️</span>
          <span class="theme-icon-dark" aria-hidden="true">🌙</span>
        </button>
      </div>
    </header>

    <!-- 🎯 核心場景引導橫向滑動看板 -->
    <section class="scene-visual-board">
      <div class="scene-visual-scroll" id="sceneVisualScroll">
        <!-- 由 JS 動態渲染高質感的場景卡片列表 -->
      </div>
    </section>

    <!-- 已啟用場景詳細資訊面板 (Active Scene Panel) -->
    <div class="active-scene-panel" id="sceneInfoBar" style="display:none;">
      <div class="scene-panel-header">
        <div class="scene-panel-title">
          <span class="scene-panel-icon" id="sceneInfoIcon"></span>
          <span class="scene-panel-name" id="sceneInfoText"></span>
        </div>
        <button class="btn btn-ghost btn-sm" id="clearScene">✕ 清除引導</button>
      </div>
      <div class="scene-panel-body">
        <div class="scene-panel-ratio" id="sceneInfoRatio"></div>
        <div class="scene-panel-tips" id="sceneInfoTips"></div>
      </div>
    </div>

    <!-- 畫廊區域 Gallery -->
    <div class="gallery-container">
      
      <!-- 🔍 全新橫向篩選工具列 (Filter Toolbar) -->
      <div class="gallery-toolbar">
        <!-- 頂部列：難度與檢視控制 -->
        <div class="toolbar-top-row">
          <div class="filter-group">
            <span class="filter-label" data-i18n="filter.difficulty">難度：</span>
            <div class="difficulty-segmented" id="difficultyFilter">
              <button class="segment-btn active" data-difficulty="all" data-i18n="filter.diff_all">全部</button>
              <button class="segment-btn" data-difficulty="beginner" data-i18n="filter.diff_beginner">入門</button>
              <button class="segment-btn" data-difficulty="intermediate" data-i18n="filter.diff_intermediate">中級</button>
              <button class="segment-btn" data-difficulty="advanced" data-i18n="filter.diff_advanced">進階</button>
            </div>
          </div>
          
          <div class="toolbar-right">
            <span class="gallery-stats" data-i18n="filter.stats"><span id="filteredCount">0</span> 個精選模板</span>
            <div class="gallery-view-toggle">
              <button class="btn-icon view-btn active" data-view="grid" id="viewGrid" data-i18n-title="filter.view_grid" title="網格檢視" aria-label="網格檢視">▦</button>
              <button class="btn-icon view-btn" data-view="list" id="viewList" data-i18n-title="filter.view_list" title="列表檢視" aria-label="列表檢視">☰</button>
            </div>
          </div>
        </div>
        
        <!-- 底部列：標籤探索列 -->
        <div class="toolbar-bottom-row">
          <div class="filter-group tag-scroll-group">
            <span class="filter-label" data-i18n="filter.tags">標籤：</span>
            <div class="horizontal-tags-container">
              <div class="horizontal-tags" id="tagFilter">
                <!-- 由 JS 動態生成 Tag Chips -->
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="gallery-grid" id="galleryGrid">
        <!-- 動態生成模板卡片 -->
      </div>

      <!-- 空狀態 Empty State -->
      <div class="empty-state" id="emptyState" style="display:none;">
        <div class="empty-icon" aria-hidden="true">🍌</div>
        <h3 data-i18n="gallery.empty_title">找不到符合的模板</h3>
        <p data-i18n="gallery.empty_desc">試試調整搜尋條件或篩選標籤</p>
      </div>
    </div>

  </main>
</div>

<!-- ============================
     模板詳情 Modal
     ============================ -->
<div class="modal-overlay" id="templateModal" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="modal-content">
    <div class="modal-header">
      <div class="modal-title-group">
        <h2 class="modal-title" id="modalTitle"></h2>
        <span class="modal-author" id="modalAuthor"></span>
      </div>
      <div class="modal-actions">
        <button class="btn-icon" id="modalFavorite" data-i18n-title="modal.favorite" title="收藏" aria-label="收藏">☆</button>
        <a class="btn-icon" id="modalSource" href="#" target="_blank" rel="noopener noreferrer" data-i18n-title="modal.source" title="原始來源" aria-label="原始來源">🔗</a>
        <button class="btn-icon modal-close" id="modalClose" data-i18n-title="modal.close" aria-label="關閉">✕</button>
      </div>
    </div>

    <div class="modal-body">
      <!-- 左側：圖片 + 資訊 -->
      <div class="modal-left">
        <div class="modal-image-container">
          <img id="modalImage" src="" alt="" class="modal-image">
        </div>
        <div class="modal-meta">
          <div class="modal-tags" id="modalTags"></div>
          <div class="modal-info">
            <span class="modal-difficulty" id="modalDifficulty"></span>
            <span class="modal-input-badge" id="modalInputBadge" style="display:none;" data-i18n="modal.input_badge">📎 需要輸入圖片</span>
          </div>
        </div>

        <!-- 場景適配 -->
        <div class="modal-section">
          <h3 class="section-title" data-i18n="modal.scene_suggestions">🎯 場景適配建議</h3>
          <div class="scene-suggestions" id="modalSceneSuggestions"></div>
        </div>
      </div>

      <!-- 右側：提示詞編輯器 -->
      <div class="modal-right">
        <!-- 語言切換 -->
        <div class="prompt-header">
          <h3 class="section-title" data-i18n="modal.prompt_title">📝 提示詞</h3>
          <div class="lang-toggle" id="langToggle" role="group" aria-label="語言切換">
            <button class="lang-btn active" data-lang="zh">中文</button>
            <button class="lang-btn" data-lang="en">English</button>
          </div>
        </div>

        <!-- 輸入提示 -->
        <div class="input-notice" id="inputNotice" style="display:none;">
          <span class="notice-icon" aria-hidden="true">📎</span>
          <span class="notice-text" id="inputNoticeText"></span>
        </div>

        <!-- 變數填寫 -->
        <div class="variables-section" id="variablesSection" style="display:none;">
          <h4 class="subsection-title" data-i18n="modal.vars_title">🔧 填寫變數</h4>
          <div class="variables-list" id="variablesList"></div>
        </div>

        <!-- 提示詞編輯器 -->
        <div class="prompt-editor">
          <div class="prompt-highlighter" id="promptHighlighter"></div>
          <textarea class="prompt-textarea" id="promptTextarea" rows="12" aria-label="提示詞編輯器"></textarea>
          <div class="prompt-char-count">
            <span id="charCount">0</span> <span data-i18n="modal.char_unit">字</span>
          </div>
        </div>

        <!-- 品質提升折疊抽屜 (Accordion) -->
        <div class="quality-accordion">
          <button class="accordion-trigger" id="qualityAccordionTrigger" aria-expanded="false" aria-controls="qualityCategories">
            <span class="trigger-text" data-i18n="modal.quality_drawer">✨ 品質提升關鍵詞 (點擊展開/收合)</span>
            <span class="trigger-arrow">▼</span>
          </button>
          <div class="accordion-content" id="qualityCategories" style="display: none;">
            <!-- 動態生成品質標籤 -->
          </div>
        </div>

        <!-- 動作按鈕 -->
        <div class="prompt-actions">
          <button class="btn btn-primary btn-lg" id="copyPrompt" data-i18n="modal.copy_btn">
            📋 複製提示詞
          </button>
          <button class="btn btn-secondary" id="resetPrompt" data-i18n="modal.reset_btn">
            🔄 重置
          </button>
          <button class="btn btn-ghost" id="saveAsCustom" data-i18n="modal.save_custom">
            💾 存為自訂模板
          </button>
          <button class="btn btn-secondary" id="editCustom" style="display:none;" data-i18n="custom.btn_edit">
            ✏️ 編輯模板
          </button>
          <button class="btn btn-danger" id="deleteCustom" style="display:none;" data-i18n="custom.btn_delete">
            🗑️ 刪除模板
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================
     圖片分析 Modal
     ============================ -->
<div class="modal-overlay" id="analysisModal" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="analysisModalTitle">
  <div class="modal-content modal-analysis">
    <div class="modal-header">
      <h2 class="modal-title" id="analysisModalTitle" data-i18n="analysis.title">🔬 圖片風格分析</h2>
      <button class="btn-icon modal-close" id="analysisClose" data-i18n-title="modal.close" aria-label="關閉">✕</button>
    </div>
    <div class="modal-body modal-body-single">
      <p class="analysis-intro" data-i18n="analysis.intro">上傳一張你喜歡的圖片，我會幫你分析其風格參數，讓你可以 remix 出類似的效果。</p>

      <!-- 圖片上傳區 -->
      <div class="upload-area" id="uploadArea">
        <div class="scan-radar" id="scanRadar" style="display: none;">
          <div class="scan-line"></div>
          <div class="scan-glow"></div>
        </div>
        <div class="upload-placeholder">
          <span class="upload-icon" aria-hidden="true">📸</span>
          <p data-i18n="analysis.placeholder">拖曳圖片到此處，或點擊上傳</p>
          <p class="upload-hint" data-i18n="analysis.hint">支援 JPG、PNG、WebP</p>
        </div>
        <input type="file" id="imageUpload" accept="image/*" hidden>
        <img id="uploadPreview" class="upload-preview" style="display:none;" alt="上傳預覽">
      </div>

      <!-- 分析結果表單 -->
      <div class="analysis-form" id="analysisForm">
        <div class="analysis-grid">
          <div class="analysis-field">
            <label class="analysis-label" for="analysisStyle" data-i18n="analysis.label_style">🎨 整體風格</label>
            <input type="text" id="analysisStyle" placeholder="例：賽博朋克、水彩、極簡主義...">
          </div>
          <div class="analysis-field">
            <label class="analysis-label" for="analysisColor" data-i18n="analysis.label_color">🌈 色彩分析</label>
            <input type="text" id="analysisColor" placeholder="例：暖色調、高飽和、霓虹配色...">
          </div>
          <div class="analysis-field">
            <label class="analysis-label" for="analysisComposition" data-i18n="analysis.label_comp">📐 構圖方式</label>
            <input type="text" id="analysisComposition" placeholder="例：居中、三分法、鳥瞰...">
          </div>
          <div class="analysis-field">
            <label class="analysis-label" for="analysisLighting" data-i18n="analysis.label_light">💡 光影效果</label>
            <input type="text" id="analysisLighting" placeholder="例：影棚燈光、自然光、戲劇性光影...">
          </div>
          <div class="analysis-field">
            <label class="analysis-label" for="analysisTexture" data-i18n="analysis.label_texture">🖌️ 材質/質感</label>
            <input type="text" id="analysisTexture" placeholder="例：磨砂、光澤、紙質、金屬...">
          </div>
          <div class="analysis-field">
            <label class="analysis-label" for="analysisMood" data-i18n="analysis.label_mood">😊 氛圍/情緒</label>
            <input type="text" id="analysisMood" placeholder="例：夢幻、溫馨、未來感、復古...">
          </div>
          <div class="analysis-field full-width">
            <label class="analysis-label" for="analysisDescription" data-i18n="analysis.label_desc">📝 詳細描述</label>
            <textarea id="analysisDescription" rows="4" placeholder="圖片的詳細描述..."></textarea>
          </div>
          <div class="analysis-field full-width">
            <label class="analysis-label" for="analysisKeywords" data-i18n="analysis.label_keywords">🔑 建議提示詞關鍵字</label>
            <textarea id="analysisKeywords" rows="3" placeholder="可用於 remix 的關鍵字..."></textarea>
          </div>
        </div>
        <div class="analysis-actions">
          <button class="btn btn-primary" id="copyAnalysis" data-i18n="analysis.btn_copy">📋 複製分析結果</button>
          <button class="btn btn-secondary" id="generateRemixPrompt" data-i18n="analysis.btn_remix">🎨 生成 Remix 提示詞</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================
     自訂模板 Modal
     ============================ -->
<div class="modal-overlay" id="customModal" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="customModalTitle">
  <div class="modal-content modal-custom">
    <div class="modal-header">
      <h2 class="modal-title" id="customModalTitle" data-i18n="custom.title">✏️ 新增自訂模板</h2>
      <button class="btn-icon modal-close" id="customClose" data-i18n-title="modal.close" aria-label="關閉">✕</button>
    </div>
    <div class="modal-body modal-body-single">
      <div class="custom-form">
        <div class="analysis-field">
          <label class="analysis-label" for="customName" data-i18n="custom.label_name">模板名稱</label>
          <input type="text" id="customName" data-i18n-placeholder="custom.placeholder_name" placeholder="為你的模板取個名字">
        </div>
        <div class="analysis-field">
          <label class="analysis-label" for="customTags" data-i18n="custom.label_tags">標籤（逗號分隔）</label>
          <input type="text" id="customTags" data-i18n-placeholder="custom.placeholder_tags" placeholder="例：風格轉換, 3D渲染, 人物">
        </div>
        <div class="analysis-field">
          <label class="analysis-label" for="customImage" data-i18n="custom.label_image">預覽圖片網址</label>
          <input type="text" id="customImage" data-i18n-placeholder="custom.placeholder_image" placeholder="填入圖片網址（選填）">
        </div>
        <div class="analysis-field">
          <label class="analysis-label" for="customDifficulty" data-i18n="custom.label_difficulty">難易度分級</label>
          <select id="customDifficulty" class="custom-select">
            <option value="beginner" data-i18n="filter.diff_beginner">入門</option>
            <option value="intermediate" selected data-i18n="filter.diff_intermediate">中級</option>
            <option value="advanced" data-i18n="filter.diff_advanced">進階</option>
          </select>
        </div>
        <div class="analysis-field full-width checkbox-field">
          <label class="checkbox-container">
            <input type="checkbox" id="customRequiresInput">
            <span class="checkbox-text" data-i18n="custom.label_requires_input">需要參考圖片作為輸入</span>
          </label>
        </div>
        <div class="analysis-field full-width" id="customInputDescContainer" style="display:none;">
          <label class="analysis-label" for="customInputDescription" data-i18n="custom.label_input_description">參考圖片用途描述</label>
          <input type="text" id="customInputDescription" data-i18n-placeholder="custom.placeholder_input_description" placeholder="例如：需上傳人物圖片作為參考圖">
        </div>
        <div class="analysis-field full-width">
          <label class="analysis-label" data-i18n="custom.label_scenes">建議適用場景（可多選）</label>
          <div class="custom-scenes-grid" id="customScenesContainer">
            <!-- JS 動態生成場景選項 -->
          </div>
        </div>
        <div class="analysis-field full-width">
          <label class="analysis-label" for="customPrompt" data-i18n="custom.label_prompt">提示詞</label>
          <textarea id="customPrompt" rows="6" data-i18n-placeholder="custom.placeholder_prompt" placeholder="輸入你的提示詞..."></textarea>
        </div>
        <div class="prompt-actions full-width">
          <button class="btn btn-primary" id="saveCustom" data-i18n="custom.btn_save">💾 儲存模板</button>
          <button class="btn btn-ghost" id="cancelCustom" data-i18n="custom.btn_cancel">取消</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================
     Toast 通知
     ============================ -->
<div class="toast-container" id="toastContainer"></div>

<!-- App Script -->
<script src="app.js" defer></script>
</body>
</html>
